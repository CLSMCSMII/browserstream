{
  "app_name": "BrowserStream",
  "public_url": "http://localhost:18080",
  "listen_address": "0.0.0.0:8080",
  "rooms": [
    {
      "id": "board-room",
      "label": "Board Room",
      "display_token": "GENERATE_A_RANDOM_DISPLAY_TOKEN"
    },
    {
      "id": "training-room",
      "label": "Training Room",
      "display_token": "GENERATE_ANOTHER_DISPLAY_TOKEN"
    }
  ],
  "turn": {
    "urls": [],
    "transport_policy": "all",
    "shared_secret": "",
