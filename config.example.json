{
  "app_name": "AwareStream",
  "public_url": "https://browserstream.example.com",
  "listen_address": "0.0.0.0:8080",
  "rooms": [
    {
      "id": "awmeeting",
      "label": "Aware Building",
      "display_token": ""
    },
    {
      "id": "smmeeting",
      "label": "Siammandalay Building",
      "display_token": ""
    }
  ],
  "turn": {
    "urls": [
      "turn:browserstream.example.com:3478"
    ],
